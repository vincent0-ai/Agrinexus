{
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["ES2020", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "moduleResolution": "Bundler",
  
      "jsx": "react-jsx",
  
      "strict": false,
      "skipLibCheck": true,
      "allowJs": true,
  
      "resolveJsonModule": true,
      "isolatedModules": true,
      "noEmit": true,
  
      "baseUrl": ".",
      "paths": {
        "@/*": ["src/*"]
      }
    },
    "include": ["src", "vite.config.ts"]
  }